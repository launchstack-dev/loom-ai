# RoadmapReadinessSchema — MVP default (archetype: default)
#
# Top-level dimensional taxonomy applied to a roadmap. One per archetype.
# Loaded by the roadmap-converge driver to discover dimensions and per-
# dimension rubrics. See planning/plans/PLAN-roadmap-converge-harness.md
# § Schema/Type Definitions for the canonical field spec.
#
# Constraints:
#   - schemaVersion: integer, required. Current = 1. Registered with the
#     F-13 migration runtime via agents/protocols/schema-versions.toon
#     under the `roadmapReadiness` entry.
#   - archetype: string, required. One of {cli, web-app, library,
#     data-pipeline, research, default}.
#   - version: string, required, semver.
#   - dimensions[]: array<DimensionDef>, required, min 1. MVP default = 8.
#
# DimensionDef columns:
#   - name: kebab-case, unique within schema
#   - rubricRef: repo-relative path to agents/protocols/roadmap-rubrics/{name}.md
#               (rubric files are authored by Phase 0b in parallel)
#   - required: true if listed in roadmap.schema.md as required section
#   - dependsOn: comma-separated list of other dimension names that must be
#                green before this dimension is evaluated. Empty = no deps.
#                Stored as the literal string "—" when empty so the TOON
#                tabular row stays positional; readers MUST treat "—" as [].

schemaVersion: 1
archetype: default
version: 1.0.0

dimensions[8]{name,rubricRef,required,dependsOn}:
  vision,agents/protocols/roadmap-rubrics/vision.md,true,—
  milestones,agents/protocols/roadmap-rubrics/milestones.md,true,vision
  tool-selection,agents/protocols/roadmap-rubrics/tool-selection.md,false,vision
  data-model,agents/protocols/roadmap-rubrics/data-model.md,true,vision
  success-metrics,agents/protocols/roadmap-rubrics/success-metrics.md,true,vision
  constraints,agents/protocols/roadmap-rubrics/constraints.md,true,—
  risks,agents/protocols/roadmap-rubrics/risks.md,true,vision
  out-of-scope,agents/protocols/roadmap-rubrics/out-of-scope.md,true,vision
