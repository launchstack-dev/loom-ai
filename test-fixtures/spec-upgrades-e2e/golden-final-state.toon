# Golden final-state snapshot for spec-upgrades-e2e.
# Generated by scripts/build-fixture.ts with pinned timestamps.
# All `now` values in the fixture builder are fixed UTC ISO strings, so the
# resulting files are byte-identical across runs and the e2e test compares
# against this snapshot.
#
# Each row is `path,size,sha256-16` where sha256-16 is the first 16 hex chars
# of the SHA-256 of the file's bytes. We keep only 16 chars because the test
# is comparing the snapshot for end-to-end stability, not cryptographic
# integrity — short hashes give human-readable diffs when something changes.
#
# Columns are pinned per change-state.schema.md path conventions:
#   - .loom/changes/{id}/{proposal.md, deltas.toon, archive-log.toon?, review-notes.md?}
#   - .loom/wiki/{contract-partition.toon, index.toon, pages/contract-{domain}.md}
#   - .plan-execution/ephemeral/changes/{id}.toon
#
# Re-generate this snapshot by running:
#   npx tsx test-fixtures/spec-upgrades-e2e/scripts/build-fixture.ts
#   npx tsx test-fixtures/spec-upgrades-e2e/scripts/snapshot-golden.ts
#
# Or just run `vitest run test/spec-upgrades-e2e.test.ts` and the test will
# emit a diff against this file when any byte changes.

