{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "..",
    "types": ["node"]
  },
  "include": [
    "lib/**/*",
    "*.ts",
    "__tests__/**/*",
    "../scripts/loom-change/proposal-frontmatter.ts",
    "../scripts/loom-change/diff.ts",
    "../scripts/lib/**/*",
    "../scripts/plan-review-harness.ts"
  ]
}
