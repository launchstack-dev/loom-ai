#!/usr/bin/env bash
# pre-commit — auto-regenerate checksums.sha256 when tracked files stage.
#
# Loom's install.sh validates downloaded files against checksums.sha256
# on cold install. When a contributor edits a tracked file (anything
# listed in the manifest) without regenerating, install.sh starts
# rejecting the download and cold installs break. This hook closes the
# regression window.
#
# Behavior:
#   - Inspect the staged paths (added/modified/renamed)
#   - If any staged path appears in checksums.sha256, run the
#     regenerator, stage the updated manifest, and continue
#   - If no tracked files staged, the hook is a no-op
#   - Always fail-open: a hook crash never blocks the commit
#
# Install once per checkout:
#   scripts/install-hooks.sh
# (sets `git config core.hooksPath scripts/git-hooks`)

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [ -z "${REPO_ROOT}" ]; then
  # Not in a git repo — let git handle whatever weirdness this is.
  exit 0
fi

MANIFEST="${REPO_ROOT}/checksums.sha256"
GENERATOR="${REPO_ROOT}/scripts/generate-checksums.sh"

# If the manifest or the generator aren't present, do nothing.
[ -f "${MANIFEST}" ] || exit 0
[ -x "${GENERATOR}" ] || exit 0

# ── Find staged paths that are tracked by the manifest ────────────────
# `git diff --cached --name-only` lists staged paths (added/modified/
# renamed/deleted). Compare against the path column of the manifest.
TRACKED_PATHS=$(awk 'NF == 2 && $1 !~ /^#/ { print $2 }' "${MANIFEST}" | sort -u)
STAGED_PATHS=$(git diff --cached --name-only --diff-filter=ACMR 2>/dev/null | sort -u)

# Intersection. `comm -12` shows lines common to both, requires sorted input.
TOUCHED=$(comm -12 <(echo "${TRACKED_PATHS}") <(echo "${STAGED_PATHS}"))

# Compute install-coverage trigger BEFORE the early-exit so a commit that
# stages only install.sh (not in checksums.sha256) still runs the check.
STAGED_COMMANDS_OR_INSTALL=""
STAGED_COMMANDS_OR_INSTALL=$(echo "${STAGED_PATHS}" | grep -E '^(commands/|install\.sh$)') || {
  _rc=$?
  if [ "${_rc}" -ne 1 ]; then
    echo "[install-coverage] grep failed rc=${_rc} — aborting" >&2
    exit 1
  fi
}

if [ -z "${TOUCHED}" ] && [ -z "${STAGED_COMMANDS_OR_INSTALL}" ]; then
  # No tracked file in this commit and no commands/install.sh staged.
  # Manifest can't have drifted via this commit.
  exit 0
fi

if [ -z "${TOUCHED}" ]; then
  # Only commands/ or install.sh staged — skip checksums regeneration,
  # fall through to the install-coverage check below.
  true
else

echo "[checksums] regenerating manifest (tracked files staged):"
echo "${TOUCHED}" | sed 's/^/  /'

if ! "${GENERATOR}"; then
  echo "[checksums] ERROR: regeneration failed — commit aborted." >&2
  echo "[checksums] Inspect the error above, then re-stage and retry." >&2
  exit 1
fi

# Re-stage the manifest if it changed.
if ! git diff --quiet -- "${MANIFEST}"; then
  git add -- "${MANIFEST}"
  echo "[checksums] checksums.sha256 updated and re-staged"
fi

fi  # end: if [ -n "${TOUCHED}" ]

# ── Install-coverage check (fail-closed) ──────────────────────────────
# Closes the gap where a new commands/*.md file is added without being
# wired into install.sh's COMMAND_FILES array (and checksums.sha256).
# End-user symptom: typing the new /loom-foo in Claude Code returns
# "Unknown command" because the curl install never copied it.
#
# Only runs when commands/ or install.sh are staged — keeps non-related
# commits fast. Delegates to test/install-command-coverage.test.ts which
# carries the actionable error output.
#
# Override: LOOM_SKIP_PRECOMMIT_QUALITY=1, or `git commit --no-verify`.

if [ -n "${STAGED_COMMANDS_OR_INSTALL}" ] && [ "${LOOM_SKIP_PRECOMMIT_QUALITY:-0}" != "1" ]; then
  if ! command -v bunx >/dev/null 2>&1; then
    echo "[install-coverage] WARNING: bunx not found — install-coverage check SKIPPED. CI remains the backstop (install-command-coverage.yml)." >&2
  else
    echo "[install-coverage] verifying commands/ ↔ install.sh COMMAND_FILES coverage"
    LOG=$(mktemp /tmp/loom-install-coverage.XXXXXX.log)
    if ! bunx vitest run --reporter=dot test/install-command-coverage.test.ts >"${LOG}" 2>&1; then
      echo "[install-coverage] ERROR: drift detected. Failure output:" >&2
      cat "${LOG}" >&2
      rm -f "${LOG}"
      echo "[install-coverage] --- Recovery ---" >&2
      echo "  1. Add the missing entries listed above to install.sh COMMAND_FILES." >&2
      echo "  2. Run: bash scripts/generate-checksums.sh" >&2
      echo "  3. git add install.sh checksums.sha256 && retry the commit." >&2
      echo "[install-coverage] Bypass with LOOM_SKIP_PRECOMMIT_QUALITY=1 (NOT recommended)." >&2
      exit 1
    fi
    rm -f "${LOG}"
  fi
fi

# ── Quality gates on staged files (fail-closed) ───────────────────────
# The PostToolUse hooks (shellcheck-on-write, bash-portability-on-write,
# pylint-on-write) catch issues at Claude write-time. This block is the
# catch-net for everything else — manual edits, merge resolution, scripted
# changes. Each gate skips silently when its tool isn't installed so the
# hook doesn't impose tooling on contributors who haven't opted in.
# Override with `git commit --no-verify` (or LOOM_SKIP_PRECOMMIT_QUALITY=1).
#
# Implementation notes:
# - Use git diff -z + NUL-delimited read to handle filenames with spaces /
#   tabs / glob chars. Unquoted `for f in $STAGED_SH` was an SC2086 in a PR
#   that introduces shellcheck-on-write. The irony was real.
# - Portability scanning delegates to scripts/portability-scan.sh which
#   shares the rule set with hooks/bash-portability-on-write.ts (single
#   source of truth at hooks/lib/portability-rules.ts).

if [ "${LOOM_SKIP_PRECOMMIT_QUALITY:-0}" = "1" ]; then
  exit 0
fi

# Collect staged files into NUL-delimited variables.
collect_staged() {
  local pattern="$1"
  local out=""
  local f
  while IFS= read -r -d '' f; do
    case "${f}" in
      *${pattern}) out="${out}${f}"$'\0' ;;
    esac
  done < <(git diff --cached -z --name-only --diff-filter=ACMR 2>/dev/null)
  printf '%s' "${out}"
}

STAGED_SH=$(collect_staged '.sh' ; collect_staged '.bash')
STAGED_PY=$(collect_staged '.py')
GATE_FAIL=0

if [ -n "${STAGED_SH}" ] && command -v shellcheck >/dev/null 2>&1; then
  echo "[shellcheck] linting staged shell scripts..."
  while IFS= read -r -d '' f; do
    shell=bash
    if head -c 64 -- "${f}" 2>/dev/null | grep -qE '^#!\s*/(usr/)?bin/sh\b'; then
      shell=sh
    fi
    if ! shellcheck -s "${shell}" -f gcc -- "${f}"; then
      GATE_FAIL=1
    fi
  done < <(printf '%s' "${STAGED_SH}")
fi

if [ -n "${STAGED_SH}" ]; then
  echo "[portability] scanning staged shell scripts for BSD/GNU divergences..."
  # Pull the files into an argv array, NUL-safely.
  files=()
  while IFS= read -r -d '' f; do
    files+=("${f}")
  done < <(printf '%s' "${STAGED_SH}")
  if [ "${#files[@]}" -gt 0 ]; then
    if ! "${REPO_ROOT}/scripts/portability-scan.sh" "${files[@]}"; then
      GATE_FAIL=1
    fi
  fi
fi

if [ -n "${STAGED_PY}" ] && command -v ruff >/dev/null 2>&1; then
  echo "[ruff] linting staged Python files..."
  py_files=()
  while IFS= read -r -d '' f; do
    py_files+=("${f}")
  done < <(printf '%s' "${STAGED_PY}")
  if [ "${#py_files[@]}" -gt 0 ]; then
    if ! ruff check --no-fix --output-format=concise -- "${py_files[@]}"; then
      GATE_FAIL=1
    fi
  fi
fi

if [ "${GATE_FAIL}" -ne 0 ]; then
  echo ""
  echo "[pre-commit] Quality gate failed. Address the findings above and re-stage." >&2
  echo "[pre-commit] To bypass (rare): git commit --no-verify" >&2
  echo "[pre-commit] To skip just this section: LOOM_SKIP_PRECOMMIT_QUALITY=1 git commit ..." >&2
  exit 1
fi
