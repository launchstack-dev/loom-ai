# Canonical reference artifact for the `/loom-init` success-output.
# Phase 3 merges this into `commands/loom-init.md` via Wave 2→3 wiring.
# Phase 8 reads this as source of truth for `test/fixtures/expected-init-output.txt`.
#
# Three required sections (acceptance criteria S-02):
#   1. filesWritten  — list of files /loom-init created or modified
#   2. suggestedNextCommand — the single recommended follow-up command
#   3. doctorPrompt  — surfaces the "Run /loom-doctor to verify" line

schemaVersion: 1
artifactKind: loom-init-success-output

successOutput:
  filesWritten[5]:
    - .claude/settings.json
    - .claude/orchestration.toml
    - CLAUDE.md
    - ROADMAP.md
    - .plan-execution/.gitkeep
  suggestedNextCommand: /loom-roadmap init --full
  doctorPrompt: Run /loom-doctor to verify your install.

# Rendering contract for commands/loom-init.md:
#   - filesWritten[] renders as a bulleted list under "Files written:"
#   - suggestedNextCommand renders verbatim in a fenced code block under "Next:"
#   - doctorPrompt renders verbatim on its own line after the Next: block
#
# Test-fixture contract for Phase 8:
#   - test/fixtures/expected-init-output.txt is generated by rendering this artifact
#     with the rules above; the integration test asserts stdout contains each
#     filesWritten entry, the suggestedNextCommand string, and the doctorPrompt string
#     (substring match, not byte-for-byte, to tolerate trailing whitespace).
